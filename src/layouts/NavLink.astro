---
const { href } = Astro.props;
const isActive = Astro.url.pathname === href;
---

<a
  href={href}
  class:list={[
    "no-animation relative transition-colors duration-200 text-sm tracking-wide",
    {
      "no-underline text-warm-900 font-medium": isActive,
      "no-underline text-warm-500 hover:text-warm-900 font-normal": !isActive,
    },
  ]}
>
  <slot />
  {isActive && <span class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-[3px] h-[3px] rounded-full bg-accent" />}
</a>
