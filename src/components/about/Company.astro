---
import FlexibleDate from "./FlexibleDate.astro";
const { title, start_date, end_date, position, stack, description, points } =
  Astro.props;

const parseDate = (date: Date) => {
  const month = date.toLocaleDateString("en-US", { month: "long" });
  const year = date.toLocaleDateString("en-US", { year: "numeric" });
  return { month, year };
};

const startDate = parseDate(start_date);
const endDate = end_date && parseDate(end_date);
const isCurrentRole = !end_date;
---

<div
  class="group relative pl-6 border-l border-warm-300 py-5 first:pt-0 last:pb-0"
>
  <div
    class:list={[
      "absolute left-0 top-0 -translate-x-1/2 -translate-y-1/2 bg-accent",
      "transition-all duration-150 ease-out",
      isCurrentRole
        ? "w-1.5 h-1.5 shadow-[0_0_0_2px_var(--color-accent-light)]"
        : "w-1 h-1",
      "group-hover:w-1.5 group-hover:h-1.5",
    ]}
  >
  </div>
  <h3 class="mb-0 text-lg">{title}</h3>
  <div class="font-mono text-sm text-warm-500 mb-1">
    <span class="font-medium text-warm-600">{position}</span>
    <span class="mx-1.5">&middot;</span>
    <FlexibleDate {...startDate} /> - {
      endDate ? <FlexibleDate {...endDate} /> : "Present"
    }
  </div>
  <div
    class="mb-3 font-mono text-xs text-warm-400 tracking-wide transition-colors duration-200 group-hover:text-warm-600 last:mb-0"
  >
    {stack.join(" · ")}
  </div>
  {
    description?.map((paragraph: string) => (
      <p class="text-base">{paragraph}</p>
    ))
  }
  {
    points && (
      <ul class="text-base">
        {points?.map((point: string) => (
          <li>{point}</li>
        ))}
      </ul>
    )
  }
</div>
