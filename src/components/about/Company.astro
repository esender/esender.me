---
import FlexibleDate from "./FlexibleDate.astro";
const { title, start_date, end_date, position, stack, description, points } =
  Astro.props;

const parseDate = (date: Date) => {
  const month = date.toLocaleDateString("en-US", { month: "long" });
  const year = date.toLocaleDateString("en-US", { year: "numeric" });
  return { month, year };
};

const startDate = parseDate(start_date);
const endDate = end_date && parseDate(end_date);
---

<div class="relative pl-6 border-l-2 border-warm-200">
  <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-accent border-2 border-warm-50"></div>
  <h3 class="mb-0">
    {title}
  </h3>
  <div class="text-base text-warm-600">
    <span class="font-medium text-warm-700">{position}</span>
    / <FlexibleDate {...startDate} />
    -
    {endDate ? <FlexibleDate {...endDate} /> : "Present"}
  </div>
  <div class="mb-4 text-base text-warm-400 last:mb-6">
    {stack}
  </div>
  {description?.map((paragraph: string) => <p>{paragraph}</p>)}
  {
    points && (
      <ul>
        {points?.map((point: string) => (
          <li>{point}</li>
        ))}
      </ul>
    )
  }
</div>
