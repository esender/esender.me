---
import type { CollectionEntry } from "astro:content";

type PostProps = CollectionEntry<"posts">["data"];
interface Props extends PostProps {
  slug: string;
}

const { title, date, category, published, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article
  class:list={[
    "grid grid-cols-12 gap-x-5 py-4 -mx-4 px-4 rounded-lg",
    "transition-all duration-300",
    "hover:bg-warm-100 hover:shadow-sm",
  ]}
>
  <h2 class:list={["mb-0 col-span-full text-2xl", "sm:col-span-9 sm:order-2"]}>
    <a class="no-underline text-warm-900 hover:text-accent-hover no-animation transition-colors duration-300" href={`/posts/${slug}`}>{title}</a>
    {
      !published && (
        <span class="bg-warm-200 inline-block px-1.5 rounded text-warm-500 text-xs uppercase font-normal align-middle">
          Draft
        </span>
      )
    }
  </h2>
  <div
    class:list={[
      "col-span-full self-end uppercase text-xs text-warm-500 pb-1",
      "sm:order-1 sm:col-span-3 sm:text-sm sm:text-right sm:pb-0 sm:row-span-2 sm:self-start",
      "lg:col-span-2",
    ]}
  >
    <div
      class:list={[
        "inline",
        "sm:block sm:mt-2.5 sm:mb-1 sm:font-medium",
        "lg:mb-1.5",
      ]}
    >
      {formattedDate}
    </div>
    <span class="sm:hidden"> /</span>
    <span class="text-[13px]">{category}</span>
  </div>
  <div
    class:list={["col-span-full text-warm-600", "sm:col-span-9 sm:order-3"]}
  >
    {description}
  </div>
</article>
