---
import type { CollectionEntry } from "astro:content";

type PostProps = CollectionEntry<"posts">["data"];
interface Props extends PostProps {
  slug: string;
}

const { title, date, category, published, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article
  class:list={[
    "group relative py-5 pl-4 cursor-pointer",
    "border-l-2 border-transparent",
    "transition-[border-color] duration-200",
    "hover:border-accent",
  ]}
>
  <a class="no-underline no-animation absolute inset-0" href={`/posts/${slug}`} tabindex="-1" aria-hidden="true" />
  <div class="font-mono text-xs text-warm-400 mb-1.5 tracking-wide">
    {formattedDate}<span class="mx-1.5">&middot;</span>{category}
    {
      !published && (
        <span class="bg-warm-200 inline-block px-1.5 rounded text-warm-500 text-xs uppercase font-normal ml-2">
          Draft
        </span>
      )
    }
  </div>
  <h2 class="mb-1 text-xl font-bold tracking-tight">
    <a class="no-underline text-warm-900 no-animation" href={`/posts/${slug}`}>{title}</a>
  </h2>
  <p class="mb-0 text-warm-600 text-base">
    {description}
  </p>
</article>
